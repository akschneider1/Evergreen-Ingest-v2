# Copy this to .env and fill in whichever key(s) you need.
# You can set both — the app picks the right one based on model selection.

# For OpenAI models (gpt-4o-mini, gpt-4o, gpt-4.1-mini, gpt-4.1)
# 128K context (gpt-4o*) or 1M context (gpt-4.1*)
OPENAI_API_KEY=your_openai_api_key_here

# For Google Gemini models (gemini-2.5-flash, gemini-2.0-flash)
# 1M context window — recommended for large documents (50+ pages)
# Much cheaper per token than OpenAI for high-volume use
# Get a key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here
