# Copy this to .env and fill in whichever key(s) you need.
# You can set multiple — the app picks the right one based on model selection.

# For Anthropic Claude models (claude-sonnet-4-6, claude-haiku-4-5, claude-opus-4-6)
# 200K context window — recommended default
# Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# For OpenAI models (gpt-4o-mini, gpt-4o, gpt-4.1-mini, gpt-4.1)
# 128K context (gpt-4o*) or 1M context (gpt-4.1*)
OPENAI_API_KEY=your_openai_api_key_here

# For Google Gemini models (gemini-2.5-flash, gemini-2.0-flash)
# 1M context window — best for very large documents (50+ pages)
# Get a key at: https://aistudio.google.com/app/apikey
# NOTE: langextract's factory looks for GEMINI_API_KEY (not GOOGLE_API_KEY).
# Set GEMINI_API_KEY for best compatibility. GOOGLE_API_KEY is also accepted
# as a fallback for existing setups.
GEMINI_API_KEY=your_google_api_key_here
# GOOGLE_API_KEY=your_google_api_key_here  # legacy alias, still works
